<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>YelpCamp</title>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous" />
	<link rel="stylesheet" href="/stylesheets/home.css ">
</head>

<body class="d-flex text-center text-white bg-dark">
	<div class="cover-container d-flex w-100 h-100 p-3 mx-auto flex-column">
		<header class="mb-auto">
			<div>
				<h3 class="float-md-start mb-0">YelpCamp</h3>
				<nav class="nav justify-content-center float-md-end">
					<a href="/" class="nav-link active">Home</a>
					<% if(!currentUser) {%>
					<a href="/login" class="nav-link ">Login</a>
					<a href="/register" class="nav-link">Register</a>
					<% } else { %>
					<a href="/logout" class="nav-l ink">Logout</a>
					<% } %>
					<a href="/campgrounds" class="nav-link">Campgrounds</a>
				</nav>
			</div>
		</header>
		<main class="px-3">
			<h1 class="mb-2">YelpCamp</h1>
			<p class="lead mb-3">Welcome to YelpCamp!<br>Explore the campgrounds on different places and feel free to share your campground and experience </p>
			<a href="/campgrounds" class="btn btn-secondary fw-bold bg-white">View Campgrounds</a>
		</main>
		<footer class=" text-white-50 mt-auto">
			<p>&copy; 2026 YelpCamp</p>
		</footer>
	</div>
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>

</html>