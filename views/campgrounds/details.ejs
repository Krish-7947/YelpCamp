<% layout('layouts/boilerplate.ejs') %>

<div class="row mb-3">
	<div class="col-6">
		<div class="card mb-3">
			<img src="<%= camp.image %>" class="card-img-top" />
			<div class="card-body">
				<h5 class="card-title"><%= camp.title%></h5>
				<p class="card-text"><%= camp.description%></p>
			</div>
			<ul class="list-group list-group-flush">
				<li class="list-group-item text-muted"><%= camp.location%></li>
				<li class="list-group-item">Submitted by : <%= camp.author.username%></li>
				<li class="list-group-item">&#8377;<%= camp.price%>/Night</li>
			</ul>
			<% if(currentUser && camp.author.equals(currentUser._id)) {%>
			<div class="card-body">
				<a href="/campgrounds/<%= camp._id %>/edit" class="btn btn-info">Edit</a>
				<form action="/campgrounds/<%= camp._id %>?_method=delete" method="post" class="d-inline">
					<button class="btn btn-danger">Delete</button>
				</form>
			</div>
			<% } %>
		</div>

	</div>
	<div class="col-6">
		<% if(currentUser) {%>
		<h2>Leave a review</h2>
		<form action="/campgrounds/<%= camp._id %>/reviews" method="post" class="mb-3 Validate-form" novalidate>
			<div class="mb-3">
				<label for="rating" class="form-label">Select Rating</label>
				<input type="range" class="form-range" min="1" max="5" id="rating" name="review[rating]">
			</div>
			<div class="mb-3">
				<label for="body" class="form-label">Review :</label>
				<textarea class="form-control" name="review[body]" id="body" rows="3" required></textarea>
			</div>
			<button class="btn btn-success">Submit</button>
		</form>
		<% } %>
		<% for(let review of camp.reviews){ %>
		<div class="card mb-3">
			<div class="card-body">
				<h5 class="card-title">Rating : <%= review.rating%></h5>
				<h6 class="card-subtitle mb-2 text-muted">By <%= review.author.username%></h6>
				<p class="card-text"><%= review.body%></p>
				<% if(currentUser && review.author.equals(currentUser._id)) {%>
				<form action="/campgrounds/<%= camp._id %>/reviews/<%= review._id %>/?_method=delete" method="post">
					<button class="btn btn-sm btn-danger">Delete</button>
				</form>
				<% } %>
			</div>
		</div>
		<% } %>
	</div>
</div>