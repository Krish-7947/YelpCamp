<% layout('layouts/boilerplate.ejs') %>

<div class="container mt-1">
	<div class="row">
		<h1 class="text-center">Edit Campground</h1>
		<div class="col-6 offset-3">
			<form action="/campgrounds/<%= camp._id %>?_method=PUT" method="post" class="Validate-form" enctype="multipart/form-data" novalidate>
				<div class="mb-3">
					<label for="title" class="form-label">Enter the title</label>
					<input type="text" id="title" name="campground[title]" class="form-control" value="<%= camp.title %>" onfocus="this.select()" required />
				</div>
				<div class="mb-3">
					<label for="location" class="form-label">Enter the location</label>
					<input type="text" id="location" name="campground[location]" class="form-control" value="<%= camp.location %>" onfocus="this.select()" required />
				</div>
				<div class="mb-3">
					<label for="formFileMultiple" class="form-label">Multiple files input example</label>
					<input class="form-control" type="file" id="formFileMultiple" name="campground[image]" multiple>
				</div>
				<div class="mb-3">
					<label for="price" class="form-label">Price :</label>
					<div class="input-group mb-3">
						<span class="input-group-text">&#8377;</span>
						<input type="number" class="form-control" name="campground[price]" value="<%= camp.price %>" onfocus="this.select()" required />
					</div>
				</div>
				<div class="mb-3">
					<label for="description" class="form-label">Description :</label>
					<textarea class="form-control" name="campground[description]" id="description" rows="3" onfocus="this.select()" required>
                    <%= camp.description %>
                    </textarea>
				</div>
				<div class="mb-3">
					<% for(let i=0;i<camp.images.length;i++) { %>
					<% if(camp.images[i].filename !== 'seed_image') { %>
					<div class="mb-3">
						<div class="form-check">
							<input class="form-check-input" type="checkbox" value="<%=camp.images[i].filename%>" name="deleteImages" id="image-<%=i%>">
							<label class=" form-check-label" for="image-<%=i%>">
								Select below image to delete
							</label>
						</div>
						<img src="<%= camp.images[i].thumbnail %>" name="img-<%=i%>" class="img-thumbnail">
					</div>
					<% } %>
					<% } %>
				</div>
				<button class="btn btn-success">Update the Campground</button><a class="btn btn-secondary ms-2" href="/campgrounds/<%= camp._id %>">Back</a>
			</form>
		</div>
	</div>
</div>

<script>
	document.querySelectorAll(".Validate-form").forEach((form) => {
		form.addEventListener("submit", (e) => {
			if (!form.checkValidity()) {
				e.preventDefault();
				e.stopPropagation();
			}

			form.classList.add("was-validated");
		});
	});
</script>